# ─────────────────────────────────────────────────────────────────────────────
# .env — LOCAL DEVELOPMENT DEFAULTS
# This file is git-ignored. Copy .env.example to create your own.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=ecom
POSTGRES_PASSWORD=ecom_dev_pass
POSTGRES_DB=ecomdb
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INTERNAL_BOOTSTRAP_SERVERS=kafka:29092

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=localDevSecretKey_ChangeInProduction_Min32Chars!
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Service Ports ─────────────────────────────────────────────────────────────
EUREKA_PORT=8761
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
MERCHANT_SERVICE_PORT=8083
ORDER_SERVICE_PORT=8084
DELIVERY_SERVICE_PORT=8085

# ── Eureka ────────────────────────────────────────────────────────────────────
EUREKA_SERVER_URL=http://eureka-server:8761/eureka/
EUREKA_SERVER_URL_LOCAL=http://localhost:8761/eureka/

# ── Payment API Keys ──────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email / Notification ──────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=dev@example.com
MAIL_PASSWORD=dev_mail_password

# ── Spring Profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local
