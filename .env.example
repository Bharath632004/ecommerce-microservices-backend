# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in your values.
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=ecom
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=ecomdb
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INTERNAL_BOOTSTRAP_SERVERS=kafka:29092

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Service Ports ─────────────────────────────────────────────────────────────
EUREKA_PORT=8761
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
MERCHANT_SERVICE_PORT=8083
ORDER_SERVICE_PORT=8084
DELIVERY_SERVICE_PORT=8085

# ── Eureka ────────────────────────────────────────────────────────────────────
EUREKA_SERVER_URL=http://eureka-server:8761/eureka/
EUREKA_SERVER_URL_LOCAL=http://localhost:8761/eureka/

# ── Payment API Keys ──────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=change_me_razorpay_key_id
RAZORPAY_KEY_SECRET=change_me_razorpay_key_secret
STRIPE_SECRET_KEY=change_me_stripe_secret_key
STRIPE_PUBLIC_KEY=change_me_stripe_public_key

# ── Email / Notification ──────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=change_me@example.com
MAIL_PASSWORD=change_me_mail_password

# ── Spring Profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local
